# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vixy_crm

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-chars

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Google Calendar Integration ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/calendar/callback

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@projectadam.co.il

# ─── Vixy Integration ─────────────────────────────────────────────────────────
VIXY_API_URL=
VIXY_API_KEY=
VIXY_WEBHOOK_SECRET=

# ─── AI Assistant ────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROVIDER=google          # ollama | google
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:12b
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-4-27b-it
