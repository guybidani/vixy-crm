generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant Core ───

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String?   @map("password_hash")
  googleId            String?   @unique @map("google_id")
  name                String
  avatarUrl           String?   @map("avatar_url")
  isActive            Boolean   @default(true) @map("is_active")
  passwordChangedAt   DateTime? @map("password_changed_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  refreshTokens   RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  ownerId   String   @map("owner_id")
  logoUrl   String?  @map("logo_url")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members             WorkspaceMember[]
  contacts            Contact[]
  companies           Company[]
  deals               Deal[]
  activities          Activity[]
  tasks               Task[]
  tags                Tag[]
  smartViews          SmartView[]
  tickets             Ticket[]
  slaPolicies         SlaPolicy[]
  cannedResponses     CannedResponse[]
  kbCategories        KbCategory[]
  kbArticles          KbArticle[]
  vixyCampaigns       VixyCampaignLink[]
  documents           Document[]
  followUpSequences   FollowUpSequence[]
  followUpExecutions  FollowUpExecution[]
  boards              Board[]
  workflows           Workflow[]
  notifications       Notification[]
  notifPreferences    NotificationPreference[]
  calendarIntegrations CalendarIntegration[]
  savedViews          SavedView[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String          @id @default(uuid())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String          @map("workspace_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String          @map("user_id")
  role        WorkspaceRole   @default(AGENT)
  invitedAt   DateTime        @default(now()) @map("invited_at")
  joinedAt    DateTime?       @map("joined_at")

  // Relations within workspace
  assignedDeals   Deal[]     @relation("DealAssignee")
  assignedTasks   Task[]     @relation("TaskAssignee")
  createdTasks    Task[]     @relation("TaskCreator")
  assignedTickets Ticket[]   @relation("TicketAssignee")
  activities      Activity[]
  createdContacts  Contact[]  @relation("ContactCreator")
  createdDocuments Document[] @relation("DocumentCreator")
  boardAccess      BoardAccess[]
  calendarIntegration CalendarIntegration?
  taskComments     TaskComment[]
  boardItemComments BoardItemComment[]
  savedViews      SavedView[]
  createdTemplates CannedResponse[] @relation("TemplateCreator")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
}

// ─── Contacts ───

model Contact {
  id             String        @id @default(uuid())
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId    String        @map("workspace_id")
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String?
  phone          String?
  company        Company?      @relation(fields: [companyId], references: [id])
  companyId      String?       @map("company_id")
  position       String?
  source         String?
  status         ContactStatus @default(LEAD)
  leadScore      Int           @default(0) @map("lead_score")
  leadHeat       LeadHeat?     @map("lead_heat")
  lastActivityAt   DateTime?     @map("last_activity_at")
  nextFollowUpDate DateTime?     @map("next_follow_up_date")
  createdBy      WorkspaceMember @relation("ContactCreator", fields: [createdById], references: [id])
  createdById    String        @map("created_by_id")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  deals              Deal[]
  activities         Activity[]
  tasks              Task[]
  tickets            Ticket[]
  tags               TagOnContact[]
  vixyCampaigns      VixyCampaignLink[]
  followUpExecutions FollowUpExecution[]
  documents          DocumentLink[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, companyId])
  @@index([workspaceId, nextFollowUpDate])
  @@index([workspaceId, deletedAt])
  @@map("contacts")
}

enum ContactStatus {
  LEAD
  QUALIFIED
  CUSTOMER
  CHURNED
  INACTIVE
}

enum LeadHeat {
  HOT        // חם מאוד / בוער
  WARM       // חם
  LUKEWARM   // פושר
  COLD       // קר
  FROZEN     // קפוא
}

enum CompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

// ─── Companies ───

model Company {
  id          String        @id @default(uuid())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String        @map("workspace_id")
  name        String
  status      CompanyStatus @default(PROSPECT)
  website     String?
  phone       String?
  email       String?
  address     String?
  industry    String?
  size        String?
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  contacts  Contact[]
  deals     Deal[]
  documents DocumentLink[]

  @@index([workspaceId])
  @@map("companies")
}

// ─── Deals ───

model Deal {
  id            String    @id @default(uuid())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId   String    @map("workspace_id")
  title         String
  value         Decimal?  @db.Decimal(12, 2)
  currency      String    @default("ILS")
  stage         DealStage @default(LEAD)
  priority      Priority  @default(MEDIUM)
  contact       Contact   @relation(fields: [contactId], references: [id])
  contactId     String    @map("contact_id")
  company       Company?  @relation(fields: [companyId], references: [id])
  companyId     String?   @map("company_id")
  assignee      WorkspaceMember @relation("DealAssignee", fields: [assigneeId], references: [id])
  assigneeId    String    @map("assignee_id")
  probability   Int       @default(0)
  expectedClose DateTime? @map("expected_close")
  stageChangedAt DateTime @default(now()) @map("stage_changed_at")
  closedAt      DateTime? @map("closed_at")
  lostReason    String?   @map("lost_reason")
  lastActivityAt DateTime? @map("last_activity_at")
  notes         String?   @db.Text
  bantData      Json?     @map("bant_data")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  activities    Activity[]
  tasks         Task[]
  tags          TagOnDeal[]
  vixyCampaigns VixyCampaignLink[]
  documents     DocumentLink[]

  @@index([workspaceId, stage])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, assigneeId])
  @@index([workspaceId, updatedAt])
  @@map("deals")
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Activities ───

model Activity {
  id          String       @id @default(uuid())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String       @map("workspace_id")
  type        ActivityType
  subject     String?
  body        String?      @db.Text
  contact     Contact?     @relation(fields: [contactId], references: [id])
  contactId   String?      @map("contact_id")
  deal        Deal?        @relation(fields: [dealId], references: [id])
  dealId      String?      @map("deal_id")
  ticket      Ticket?      @relation(fields: [ticketId], references: [id])
  ticketId    String?      @map("ticket_id")
  member      WorkspaceMember @relation(fields: [memberId], references: [id])
  memberId    String       @map("member_id")
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([workspaceId, contactId])
  @@index([workspaceId, memberId])
  @@index([workspaceId, dealId])
  @@index([workspaceId, ticketId])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  WHATSAPP
  STATUS_CHANGE
  SYSTEM
}

// ─── Tasks ───

enum TaskType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  FOLLOW_UP
  TASK
}

enum TaskContext {
  SALES
  SERVICE
  GENERAL
}

enum CallResult {
  ANSWERED
  VOICEMAIL
  NO_ANSWER
  BUSY
  RESCHEDULED
  NOT_RELEVANT
}

model Task {
  id          String     @id @default(uuid())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String     @map("workspace_id")
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  taskType    TaskType   @default(TASK) @map("task_type")
  taskContext  TaskContext @default(GENERAL) @map("task_context")
  dueDate     DateTime?  @map("due_date")
  contact     Contact?   @relation(fields: [contactId], references: [id])
  contactId   String?    @map("contact_id")
  deal        Deal?      @relation(fields: [dealId], references: [id])
  dealId      String?    @map("deal_id")
  ticket      Ticket?    @relation(fields: [ticketId], references: [id])
  ticketId    String?    @map("ticket_id")
  assignee    WorkspaceMember @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String     @map("assignee_id")
  createdBy   WorkspaceMember @relation("TaskCreator", fields: [createdById], references: [id])
  createdById String     @map("created_by_id")
  dueTime                String?    @map("due_time")          // "HH:mm" e.g. "14:30"
  reminderMinutes        Int?       @default(15) @map("reminder_minutes")
  completedAt            DateTime?  @map("completed_at")
  outcomeNote            String?    @map("outcome_note")
  callResult             CallResult? @map("call_result")
  snoozedUntil           DateTime?  @map("snoozed_until")
  googleCalendarEventId  String?    @map("google_calendar_event_id")
  // Recurrence
  isRecurring       Boolean    @default(false) @map("is_recurring")
  recurrenceType    String?    @map("recurrence_type") // DAILY, WEEKLY, BIWEEKLY, MONTHLY
  recurrenceDay     Int?       @map("recurrence_day") // Day of week (0=Sun) or day of month
  recurrenceEndDate DateTime?  @map("recurrence_end_date")
  parentTaskId      String?    @map("parent_task_id")
  parentTask        Task?      @relation("RecurringTask", fields: [parentTaskId], references: [id])
  childTasks        Task[]     @relation("RecurringTask")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  comments   TaskComment[]

  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
  @@index([workspaceId, taskType])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, completedAt])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String   @map("task_id")
  author    WorkspaceMember @relation(fields: [authorId], references: [id])
  authorId  String   @map("author_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([taskId])
  @@map("task_comments")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// ─── Tags ───

model Tag {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  name        String
  color       String    @default("#0073EA")
  createdAt   DateTime  @default(now()) @map("created_at")

  contacts TagOnContact[]
  deals    TagOnDeal[]

  @@unique([workspaceId, name])
  @@map("tags")
}

model TagOnContact {
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String  @map("contact_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String  @map("tag_id")

  @@id([contactId, tagId])
  @@map("tags_on_contacts")
}

model TagOnDeal {
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId String @map("deal_id")
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String @map("tag_id")

  @@id([dealId, tagId])
  @@map("tags_on_deals")
}

// ─── Smart Views ───

model SmartView {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  name        String
  module      String    // "contacts" | "deals" | "tickets"
  filters     Json
  memberId    String?   @map("member_id")
  isShared    Boolean   @default(false) @map("is_shared")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("smart_views")
}

// ─── Support: Tickets ───

enum UrgencyLevel {
  CRITICAL   // דחוף מאוד
  HIGH       // דחוף
  MEDIUM     // בינוני
  LOW        // נמוך
}

model Ticket {
  id              String       @id @default(uuid())
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId     String       @map("workspace_id")
  subject         String
  description     String?      @db.Text
  status          TicketStatus @default(NEW)
  priority        Priority     @default(MEDIUM)
  urgencyLevel    UrgencyLevel @default(MEDIUM) @map("urgency_level")
  channel         String       @default("email")
  contact         Contact?     @relation(fields: [contactId], references: [id])
  contactId       String?      @map("contact_id")
  assignee        WorkspaceMember? @relation("TicketAssignee", fields: [assigneeId], references: [id])
  assigneeId      String?      @map("assignee_id")
  slaPolicy       SlaPolicy?   @relation(fields: [slaPolicyId], references: [id])
  slaPolicyId     String?      @map("sla_policy_id")
  firstResponseAt DateTime?    @map("first_response_at")
  resolvedAt      DateTime?    @map("resolved_at")
  csatScore       Int?         @map("csat_score")
  csatComment     String?      @map("csat_comment")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  messages   TicketMessage[]
  activities Activity[]
  tasks      Task[]
  documents  DocumentLink[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, assigneeId])
  @@map("tickets")
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    String   @map("ticket_id")
  senderType  String   // "agent" | "contact"
  senderId    String   @map("sender_id")
  body        String   @db.Text
  isInternal  Boolean  @default(false) @map("is_internal")
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_messages")
}

// ─── Support: SLA ───

model SlaPolicy {
  id                    String    @id @default(uuid())
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId           String    @map("workspace_id")
  name                  String
  firstResponseMinutes  Int       @map("first_response_minutes")
  resolutionMinutes     Int       @map("resolution_minutes")
  businessHoursOnly     Boolean   @default(true) @map("business_hours_only")
  isDefault             Boolean   @default(false) @map("is_default")
  createdAt             DateTime  @default(now()) @map("created_at")

  tickets Ticket[]

  @@map("sla_policies")
}

// ─── Support: Canned Responses ───

model CannedResponse {
  id          String   @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String   @map("workspace_id")
  name        String
  category    String   @default("GENERAL") // SALES, SERVICE, GENERAL
  channel     String   @default("EMAIL")   // EMAIL, WHATSAPP, SMS
  subject     String?  // Email subject line
  body        String   @db.Text
  variables   Json?    // [{ name: "firstName", label: "שם פרטי" }]
  isActive    Boolean  @default(true) @map("is_active")
  usageCount  Int      @default(0) @map("usage_count")
  createdBy   WorkspaceMember @relation("TemplateCreator", fields: [createdById], references: [id])
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, category])
  @@map("canned_responses")
}

// ─── Support: Knowledge Base ───

model KbCategory {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  name        String
  slug        String
  order       Int       @default(0)
  parentId    String?   @map("parent_id")
  parent      KbCategory? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    KbCategory[] @relation("CategoryChildren")
  createdAt   DateTime  @default(now()) @map("created_at")

  articles KbArticle[]

  @@unique([workspaceId, slug])
  @@map("kb_categories")
}

model KbArticle {
  id              String     @id @default(uuid())
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId     String     @map("workspace_id")
  title           String
  slug            String
  body            String     @db.Text
  category        KbCategory? @relation(fields: [categoryId], references: [id])
  categoryId      String?    @map("category_id")
  status          String     @default("draft")
  authorId        String     @map("author_id")
  viewCount       Int        @default(0) @map("view_count")
  helpfulCount    Int        @default(0) @map("helpful_count")
  notHelpfulCount Int        @default(0) @map("not_helpful_count")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@unique([workspaceId, slug])
  @@map("kb_articles")
}

// ─── Documents ───

enum DocumentType {
  FILE
  RICH_TEXT
}

model Document {
  id          String       @id @default(uuid())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String       @map("workspace_id")
  type        DocumentType
  title       String
  content     String?      @db.Text
  fileName    String?      @map("file_name")
  fileUrl     String?      @map("file_url")
  fileSize    Int?         @map("file_size")
  mimeType    String?      @map("mime_type")
  createdBy   WorkspaceMember @relation("DocumentCreator", fields: [createdById], references: [id])
  createdById String       @map("created_by_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  links DocumentLink[]

  @@map("documents")
}

model DocumentLink {
  id         String   @id @default(uuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String   @map("document_id")
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId  String?  @map("contact_id")
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId     String?  @map("deal_id")
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId  String?  @map("company_id")
  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   String?  @map("ticket_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([documentId, contactId, dealId, companyId, ticketId])
  @@map("document_links")
}

// ─── Follow-Up Automation ───

enum FollowUpChannel {
  EMAIL
  WHATSAPP
  SMS
  CALL_TASK
}

enum FollowUpExecutionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model FollowUpSequence {
  id              String          @id @default(uuid())
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId     String          @map("workspace_id")
  name            String
  description     String?
  triggerStatuses  ContactStatus[] @map("trigger_statuses")
  endAction       String          @default("MOVE_INACTIVE") @map("end_action")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  steps      FollowUpStep[]
  executions FollowUpExecution[]

  @@map("follow_up_sequences")
}

model FollowUpStep {
  id              String           @id @default(uuid())
  sequence        FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sequenceId      String           @map("sequence_id")
  stepNumber      Int              @map("step_number")
  delayDays       Int              @map("delay_days")
  channel         FollowUpChannel
  messageTemplate String?          @map("message_template")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@map("follow_up_steps")
}

model FollowUpExecution {
  id            String                   @id @default(uuid())
  workspace     Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId   String                   @map("workspace_id")
  sequence      FollowUpSequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sequenceId    String                   @map("sequence_id")
  contact       Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId     String                   @map("contact_id")
  currentStep   Int                      @default(0) @map("current_step")
  status        FollowUpExecutionStatus  @default(ACTIVE)
  nextRunAt     DateTime?                @map("next_run_at")
  lastStepAt    DateTime?                @map("last_step_at")
  completedAt   DateTime?                @map("completed_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  @@index([workspaceId, status])
  @@index([nextRunAt])
  @@map("follow_up_executions")
}

// ─── Vixy Integration ───

model VixyCampaignLink {
  id               String    @id @default(uuid())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId      String    @map("workspace_id")
  vixyCampaignId   String    @map("vixy_campaign_id")
  vixyCampaignName String?   @map("vixy_campaign_name")
  contact          Contact?  @relation(fields: [contactId], references: [id])
  contactId        String?   @map("contact_id")
  deal             Deal?     @relation(fields: [dealId], references: [id])
  dealId           String?   @map("deal_id")
  metadata         Json?
  syncedAt         DateTime  @default(now()) @map("synced_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("vixy_campaign_links")
}

// ─── Automations ───

enum WorkflowTrigger {
  DEAL_STAGE_CHANGED
  DEAL_CREATED
  CONTACT_CREATED
  CONTACT_STATUS_CHANGED
  TASK_CREATED
  TASK_COMPLETED
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  LEAD_SCORE_CHANGED
  ENTITY_UPDATED
}

enum WorkflowActionType {
  SEND_NOTIFICATION
  CREATE_TASK
  CHANGE_FIELD
  SEND_EMAIL
  ADD_TAG
  MOVE_STAGE
  ASSIGN_OWNER
}

model Workflow {
  id          String           @id @default(uuid())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String           @map("workspace_id")
  name        String
  description String?
  trigger     WorkflowTrigger
  conditions  Json?            // { field, operator, value }[]
  isActive    Boolean          @default(true) @map("is_active")
  createdById String           @map("created_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  actions WorkflowAction[]
  runs    WorkflowRun[]

  @@index([workspaceId, trigger])
  @@map("workflows")
}

model WorkflowAction {
  id         String             @id @default(uuid())
  workflow   Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId String            @map("workflow_id")
  type       WorkflowActionType
  config     Json               // action-specific config
  order      Int                @default(0)

  @@index([workflowId, order])
  @@map("workflow_actions")
}

model WorkflowRun {
  id          String   @id @default(uuid())
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId  String   @map("workflow_id")
  triggeredBy String?  @map("triggered_by") // entity id that triggered
  entityType  String?  @map("entity_type")  // "deal", "contact", etc.
  entityId    String?  @map("entity_id")
  status      String   @default("SUCCESS")  // SUCCESS, FAILED
  error       String?
  executedAt  DateTime @default(now()) @map("executed_at")

  @@index([workflowId])
  @@map("workflow_runs")
}

// ─── Notifications ───

enum NotificationType {
  AUTOMATION
  DAILY_DIGEST
  DEAL_UPDATE
  TASK_ASSIGNED
  TASK_DUE
  TICKET_UPDATE
  CONTACT_UPDATE
  SYSTEM
  MENTION
}

model Notification {
  id          String           @id @default(uuid())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String           @map("workspace_id")
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  body        String?
  entityType  String?          @map("entity_type") // "deal", "contact", etc.
  entityId    String?          @map("entity_id")
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([workspaceId, userId, isRead])
  @@index([workspaceId, userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  type        NotificationType
  inApp       Boolean   @default(true) @map("in_app")
  email       Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, userId, type])
  @@map("notification_preferences")
}

// ─── Audit Log ───

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String?  @map("workspace_id")
  userId      String   @map("user_id")
  action      String   // e.g. "user.login", "sla.create", "automation.delete"
  entityType  String?  @map("entity_type") // e.g. "SlaPolicy", "Workflow"
  entityId    String?  @map("entity_id")
  metadata    Json?    // extra context (old values, new values, etc.)
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── Custom Boards ───

enum BoardColumnType {
  TEXT
  NUMBER
  STATUS
  DATE
  PERSON
  EMAIL
  PHONE
  LINK
  PRIORITY
  CHECKBOX
}

model Board {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  icon        String?   @default("LayoutGrid")
  color       String?   @default("#579BFC")
  templateKey String?   @map("template_key")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  isPrivate   Boolean       @default(false) @map("is_private")
  automations Json?
  columns     BoardColumn[]
  groups      BoardGroup[]
  items       BoardItem[]
  access      BoardAccess[]

  @@index([workspaceId])
  @@map("boards")
}

model BoardColumn {
  id      String          @id @default(uuid())
  board   Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String          @map("board_id")
  key     String
  label   String
  type    BoardColumnType @default(TEXT)
  width   String?         @default("150px")
  order   Int             @default(0)
  options Json?

  values BoardItemValue[]

  @@index([boardId, order])
  @@map("board_columns")
}

model BoardGroup {
  id        String  @id @default(uuid())
  board     Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId   String  @map("board_id")
  name      String
  color     String  @default("#579BFC")
  order     Int     @default(0)
  collapsed Boolean @default(false)

  items BoardItem[]

  @@index([boardId, order])
  @@map("board_groups")
}

model BoardItem {
  id           String      @id @default(uuid())
  board        Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId      String      @map("board_id")
  group        BoardGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String      @map("group_id")
  name         String
  order        Int         @default(0)
  done         Boolean     @default(false)
  parentItemId String?     @map("parent_item_id")
  parentItem   BoardItem?  @relation("SubItems", fields: [parentItemId], references: [id], onDelete: Cascade)
  subItems     BoardItem[] @relation("SubItems")
  createdAt    DateTime    @default(now()) @map("created_at")

  values   BoardItemValue[]
  comments BoardItemComment[]
  files    BoardItemFile[]

  @@index([groupId, order])
  @@index([parentItemId])
  @@map("board_items")
}

model BoardItemFile {
  id           String    @id @default(uuid())
  item         BoardItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId       String    @map("item_id")
  fileName     String    @map("file_name")
  fileUrl      String    @map("file_url")
  fileSize     Int       @map("file_size")
  mimeType     String    @map("mime_type")
  uploadedById String    @map("uploaded_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([itemId])
  @@map("board_item_files")
}

model BoardItemComment {
  id        String          @id @default(uuid())
  item      BoardItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String          @map("item_id")
  author    WorkspaceMember @relation(fields: [authorId], references: [id])
  authorId  String          @map("author_id")
  body      String          @db.Text
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([itemId])
  @@map("board_item_comments")
}

model BoardItemValue {
  id          String      @id @default(uuid())
  item        BoardItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String      @map("item_id")
  column      BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId    String      @map("column_id")
  textValue   String?     @map("text_value")
  numberValue Float?      @map("number_value")
  dateValue   DateTime?   @map("date_value")
  jsonValue   Json?       @map("json_value")

  @@unique([itemId, columnId])
  @@map("board_item_values")
}

// ─── Board Access / Permissions ───

enum BoardPermission {
  VIEWER
  EDITOR
  ADMIN
}

model BoardAccess {
  id          String          @id @default(uuid())
  board       Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId     String          @map("board_id")
  member      WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId    String          @map("member_id")
  permission  BoardPermission @default(VIEWER)
  grantedBy   String?         @map("granted_by")
  grantedAt   DateTime        @default(now()) @map("granted_at")

  @@unique([boardId, memberId])
  @@index([boardId])
  @@index([memberId])
  @@map("board_access")
}

// ─── Google Calendar Integration ───

model CalendarIntegration {
  id               String          @id @default(uuid())
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId      String          @map("workspace_id")
  member           WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId         String          @unique @map("member_id")
  accessToken      String          @map("access_token") @db.Text
  refreshToken     String          @map("refresh_token") @db.Text
  expiresAt        DateTime        @map("expires_at")
  googleEmail      String          @map("google_email")
  googleCalendarId String          @default("primary") @map("google_calendar_id")
  isActive         Boolean         @default(true) @map("is_active")
  connectedAt      DateTime        @default(now()) @map("connected_at")
  lastSyncedAt     DateTime?       @map("last_synced_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@unique([workspaceId, memberId])
  @@index([workspaceId])
  @@index([memberId])
  @@map("calendar_integrations")
}

// ─── Saved Views (Favorite Filters) ───

model SavedView {
  id          String          @id @default(uuid())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String          @map("workspace_id")
  member      WorkspaceMember @relation(fields: [memberId], references: [id])
  memberId    String          @map("member_id")
  entity      String          // "contacts", "deals", "tasks", "tickets"
  name        String
  filters     Json            // { status: "LEAD", priority: "HIGH", ... }
  isDefault   Boolean         @default(false) @map("is_default")
  sortBy      String?         @map("sort_by")
  sortDir     String?         @map("sort_dir")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([workspaceId, memberId, entity])
  @@map("saved_views")
}
