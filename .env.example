# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vixy_crm

# Redis
REDIS_URL=redis://localhost:6381

# Auth (min 32 chars each in production)
JWT_SECRET=change-me-to-random-32-char-string!!
JWT_REFRESH_SECRET=change-me-to-different-random-string!!

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=

# Client (Vite build-time variable)
VITE_API_URL=http://localhost:3001/api/v1

# Vixy Integration (optional)
VIXY_API_URL=
VIXY_API_KEY=
VIXY_WEBHOOK_SECRET=

# Google OAuth (used for login + calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/calendar/callback
VITE_GOOGLE_CLIENT_ID=
